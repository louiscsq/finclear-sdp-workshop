          },
          "position": {
            "x": 0,
            "y": 0,
            "width": 6,
            "height": 1
          }
        },
        {
          "widget": {
            "name": "subtitle",
            "multilineTextboxSpec": {
              "lines": [
                "Gold marts served from the Artie CDC \u2192 bronze \u2192 silver \u2192 gold pipeline. Business metrics, data-quality (expectations), and serverless cost."
              ]
