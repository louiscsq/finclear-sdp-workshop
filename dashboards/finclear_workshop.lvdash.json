{
  "datasets": [
    {
      "name": "ds_portfolio",
      "displayName": "Portfolio valuation",
      "queryLines": [
        "SELECT * FROM finclear_sdp_demo_catalog.sdp_workshop.gold_portfolio_valuation"
      ]
    },
    {
      "name": "ds_trades",
      "displayName": "Daily trade activity",
      "queryLines": [
        "SELECT * FROM finclear_sdp_demo_catalog.sdp_workshop.gold_daily_trade_activity"
      ]
    },
    {
      "name": "ds_notes",
      "displayName": "Contract notes",
      "queryLines": [
        "SELECT * FROM finclear_sdp_demo_catalog.sdp_workshop.gold_contract_note_summary"
      ]
    },
    {
      "name": "ds_dq",
      "displayName": "Data quality (expectations)",
      "queryLines": [
        "SELECT replace(origin.flow_name,'finclear_sdp_demo_catalog.sdp_workshop.','') AS table_name, SUM(CAST(details:flow_progress.data_quality.dropped_records AS BIGINT)) AS dropped_records, SUM(CAST(details:flow_progress.data_quality.warned_records AS BIGINT)) AS warned_records FROM event_log('a7ab19ed-de5d-49a4-a87b-3dbfa3587b12') WHERE event_type='flow_progress' AND details:flow_progress.data_quality IS NOT NULL GROUP BY 1 HAVING table_name <> ''"
      ]
    },
    {
      "name": "ds_cost",
      "displayName": "Serverless usage (this pipeline)",
      "queryLines": [
        "SELECT usage_date, sku_name, ROUND(SUM(usage_quantity),3) AS dbus FROM system.billing.usage WHERE usage_metadata.dlt_pipeline_id = 'a7ab19ed-de5d-49a4-a87b-3dbfa3587b12' AND usage_date >= current_date() - 30 GROUP BY 1,2"
      ]
    }
  ],
  "pages": [
    {
      "name": "overview",
      "displayName": "Overview",
      "pageType": "PAGE_TYPE_CANVAS",
      "layout": [
        {
          "widget": {
            "name": "title",
            "multilineTextboxSpec": {
              "lines": [
                "## FinClear \u2014 Summit Medallion (SDP demo)"
              ]
